#!/bin/bash

declare -A info

####################
lock() { loginctl lock-session; }
info[lock]="Lock the current session"

####################
logout() { loginctl terminate-session self; }
info[logout]="Log out of the current session"

####################
poweroff() { systemctl poweroff; }
info[poweroff]="Power off the system"

####################
reboot() { systemctl reboot; }
info[reboot]="Reboot the system"

####################
sleep()
{
    case "$1" in
        -b|--on-battery)
            grep -q '1' /sys/class/power_supply/AC*/online 2>/dev/null && return 0;;
    esac
    systemctl sleep
}
info[sleep]="Put the system to sleep: sleep [-b|--on-battery]"

####################
help()
{
    echo "
Usage: $(basename "$0") <action> [args...]

Where <action> is one of:"
    actions=$(printf "%s\n" "${!info[@]}" | sort)
    for action in $actions; do
        printf "   %-10s %s\n" "$action" "${info[$action]}"
    done
    echo
}
info[help]="Show this help screen and exit"

####################
paths=(
    "/usr/share/sessionctl"
    "/etc/sessionctl"
    "$HOME/.config/sessionctl"
)
desktop="${XDG_CURRENT_DESKTOP%%:*}"

for path in "${paths[@]}"; do
    [[ -f "$path/$desktop" ]] && source "$path/$desktop"
done

####################
[[ "$1" == "-h" || "$1" == "--help" ]] && action="help" || action="$1"
shift 2>/dev/null

[[ -v "info[$action]" ]] && "$action" "$@"
