#!/bin/bash

declare -A help

lock() { loginctl lock-session; }
help[lock]="Lock the current session"

logout() { loginctl terminate-session self; }
help[logout]="Log out of the current session"

monitors() { :; }

poweroff() { systemctl poweroff; }
help[poweroff]="Power off the system"

reboot() { systemctl reboot; }
help[reboot]="Reboot the system"

sleep()
{
    case "$1" in
        -b|--on-battery)
            grep -q '1' /sys/class/power_supply/AC*/online 2>/dev/null && return 0;;
    esac
    systemctl sleep
}
help[sleep]="Put the system to sleep: sleep [-b|--on-battery]"

paths=(
    "$HOME/.config/sessionctl"
    "/etc/sessionctl"
    "/usr/share/sessionctl"
)
desktop="${XDG_CURRENT_DESKTOP%%:*}"

for path in "${paths[@]}"; do
    if [[ -f "$path/$desktop" ]]; then
        source "$path/$desktop"
        break
    fi
done

action="$1"
shift 2>/dev/null

case "$action" in
    lock) lock "$@";;
    logout) logout "$@";;
    monitors) monitors "$@";;
    suspend) suspend "$@";;

    *) echo "
Usage: $(basename "$0") <action> [args...]

Where <action> is one of:"
        actions=$(printf "%s\n" "${!help[@]}" | sort)
        for action in $actions; do
            printf "   %-10s %s\n" "$action" "${help[$action]}"
        done
        echo
        ;;
esac
